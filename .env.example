# SiliconFlow (硅基流动) API Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# 截图优化设置 (可选)
CAPTURE_OFFSET=2.0
VIDEO_PATH=input.mp4
OUTPUT_DIR=fast_output
MODEL_SIZE=medium
DEVICE=cuda
COMPUTE_TYPE=float16

# MinIO（Web 版必填）
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=leader
MINIO_SECURE=false

# 可选：用于给浏览器生成可直连访问的 URL（跨机器/容器时建议配置）
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000

# 可选：yt-dlp 代理（YouTube 常用）
# YTDLP_PROXY=http://127.0.0.1:7897

# 可选：本地 Tesseract OCR
# TESSDATA_PREFIX=E:\leader\model\tessdata
# TESSERACT_LANG=chi_sim+eng
